# ============================================================
# AI OS — Configuracion
# Copia este archivo a .env y rellena lo que uses.
# ============================================================

# === LLM PRIMARIO: Ollama local con modelo Hermes ===
# Es la opcion mas simple y 100% privada. Todo corre en tu PC.
# 1. Instala Ollama:  https://ollama.com
# 2. Descarga Hermes: ollama pull hermes
# 3. Verifica:        ollama list
LLM_OLLAMA_ENABLED=true
LLM_OLLAMA_MODEL=hermes
LLM_OLLAMA_BASE=http://localhost:11434

# === LLM SECUNDARIO: NVIDIA Megatron / NIM (opcional) ===
# Solo si tienes Megatron 5.5 corriendo localmente. Si no, deja ENABLED=false.
# Megatron expone API OpenAI-compatible, por eso el prefijo "openai/".
LLM_MEGATRON_ENABLED=false
LLM_MEGATRON_MODEL=openai/megatron-5.5
LLM_MEGATRON_BASE=http://localhost:8000/v1
LLM_MEGATRON_KEY=nvidia-megatron

# === LLM TERCIARIO: OpenAI cloud (opcional, para tareas complejas) ===
LLM_OPENAI_ENABLED=false
LLM_OPENAI_MODEL=gpt-4o
LLM_OPENAI_KEY=sk-...

# === LLM CUATERNARIO: Anthropic Claude (opcional) ===
LLM_ANTHROPIC_ENABLED=false
LLM_ANTHROPIC_MODEL=claude-3-5-sonnet-20240620
LLM_ANTHROPIC_KEY=sk-ant-...

# === Timeout global del LLM en segundos ===
LLM_TIMEOUT=120
LLM_TEMPERATURE=0.3

# === Agente Memory (ChromaDB) ===
# Para que Hermes recuerde entre sesiones
MEMORY_DB_PATH=./data/memory_db
# Modelo de embeddings de Ollama (gratis y local)
MEMORY_EMBEDDING_MODEL=ollama/nomic-embed-text
MEMORY_EMBEDDING_BASE=http://localhost:11434

# === Agente Browser (Playwright) ===
BROWSER_HEADLESS=true
BROWSER_USER_DATA_DIR=./data/browser_profile

# === Agente Home Assistant ===
# Solo si tienes HA instalado. Crea un Long-Lived Access Token en tu perfil.
HA_BASE_URL=http://homeassistant.local:8123
HA_TOKEN=

# === Agente n8n ===
# Solo si tienes n8n corriendo. Por defecto: docker run -p 5678:5678 n8nio/n8n
N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=

# === Aprobacion humana ===
# Si true, las acciones marcadas como peligrosas en agent.json piden confirmacion
APPROVAL_ENABLED=true
# Timeout en segundos para esperar aprobacion (0 = espera infinita)
APPROVAL_TIMEOUT=120
